generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  STAFF
  ROOT
}

enum StudentStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum CoinTransactionType {
  EARN
  DEDUCT
  RESERVE
  REFUND
}

enum ShopOrderStatus {
  PENDING
  APPROVED
  RECEIVED
  CANCELLED
}

enum NotificationType {
  INFO
  WARNING
  REWARD
  SHOP
  SYSTEM
}

model User {
  id                 String              @id @default(cuid())
  telegramId         String?             @unique
  username           String              @unique
  email              String?             @unique
  role               UserRole            @default(STUDENT)
  passwordHash       String?
  failedLoginCount   Int                 @default(0)
  lockedUntil        DateTime?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  studentProfile     StudentProfile?
  approvedStudents   StudentProfile[]    @relation("StudentApprovedBy")
  coinTransactions   CoinTransaction[]
  userBadges         UserBadge[]         @relation("UserBadges")
  awardedBadges      UserBadge[]         @relation("BadgeAwardedBy")
  createdEvents      Event[]             @relation("EventCreatedBy")
  eventRegistrations EventRegistration[]
  shopOrders         ShopOrder[]         @relation("ShopOrderUser")
  approvedOrders     ShopOrder[]         @relation("ShopOrderApprovedBy")
  notifications      Notification[]
  auditLogs          AuditLog[]          @relation("AuditActor")
  staffAssignments   StaffAssignment[]   @relation("StaffAssignments")
  sessions           AuthSession[]
  announcements      Announcement[]      @relation("AnnouncementCreatedBy")
}

model StudentProfile {
  id         String        @id @default(cuid())
  userId     String        @unique
  studentId  String        @unique
  fullName   String
  facultyId  String
  groupId    String
  status     StudentStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  joinedAt   DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  faculty    Faculty       @relation(fields: [facultyId], references: [id])
  group      Group         @relation(fields: [groupId], references: [id])
  approver   User?         @relation("StudentApprovedBy", fields: [approvedBy], references: [id])

  @@index([facultyId])
  @@index([groupId])
}

model Faculty {
  id               String            @id @default(cuid())
  name             String
  code             String            @unique
  createdAt        DateTime          @default(now())
  students         StudentProfile[]
  groups           Group[]
  events           Event[]
  staffAssignments StaffAssignment[] @relation("FacultyStaffAssignments")
  announcements    Announcement[]
}

model Group {
  id               String            @id @default(cuid())
  facultyId        String
  name             String
  code             String            @unique
  joinCode         String            @unique
  coinBalance      Int               @default(0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  faculty          Faculty           @relation(fields: [facultyId], references: [id])
  students         StudentProfile[]
  staffAssignments StaffAssignment[] @relation("GroupStaffAssignments")
  announcements    Announcement[]

  @@index([facultyId])
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
}

model CoinTransaction {
  id          String              @id @default(cuid())
  userId      String
  amount      Int
  type        CoinTransactionType
  reason      String
  referenceId String?
  createdAt   DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([referenceId])
}

model Badge {
  id              String      @id @default(cuid())
  name            String
  description     String
  nameI18n        Json?
  descriptionI18n Json?
  iconUrl         String?
  requiredCoins   Int         @default(0)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  userBadges      UserBadge[]
}

model UserBadge {
  id         String    @id @default(cuid())
  userId     String
  badgeId    String
  awardedAt  DateTime  @default(now())
  awardedBy  String?
  note       String?
  user       User      @relation("UserBadges", fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awarder    User?     @relation("BadgeAwardedBy", fields: [awardedBy], references: [id])

  @@unique([userId, badgeId])
  @@index([badgeId])
}

model Event {
  id              String                @id @default(cuid())
  title           String
  description     String
  titleI18n       Json?
  descriptionI18n Json?
  facultyId       String?
  startAt         DateTime
  endAt           DateTime?
  createdBy       String
  isPublished     Boolean               @default(false)
  coinsReward     Int                   @default(0)
  createdAt       DateTime              @default(now())
  faculty         Faculty?              @relation(fields: [facultyId], references: [id])
  creator         User                  @relation("EventCreatedBy", fields: [createdBy], references: [id])
  registrations   EventRegistration[]

  @@index([facultyId])
  @@index([startAt])
}

model EventRegistration {
  id           String   @id @default(cuid())
  eventId       String
  userId        String
  registeredAt  DateTime @default(now())
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

model ShopItem {
  id              String      @id @default(cuid())
  name            String
  description     String
  nameI18n        Json?
  descriptionI18n Json?
  imageUrl        String?
  coinCost        Int
  stock           Int         @default(0)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  orders          ShopOrder[]
}

model ShopOrder {
  id         String          @id @default(cuid())
  userId     String
  itemId     String
  quantity   Int             @default(1)
  totalCost  Int
  status     ShopOrderStatus @default(PENDING)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  approvedBy String?
  approvedAt DateTime?
  receivedAt DateTime?
  user       User            @relation("ShopOrderUser", fields: [userId], references: [id], onDelete: Cascade)
  item       ShopItem        @relation(fields: [itemId], references: [id])
  approver   User?           @relation("ShopOrderApprovedBy", fields: [approvedBy], references: [id])

  @@index([userId, status])
  @@index([itemId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  titleI18n Json?
  body      String
  bodyI18n  Json?
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Announcement {
  id              String    @id @default(cuid())
  title           String
  body            String
  titleI18n       Json?
  bodyI18n        Json?
  createdBy       String
  facultyId       String?
  groupId         String?
  isPublished     Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  creator         User      @relation("AnnouncementCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)
  faculty         Faculty?  @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  group           Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([facultyId])
  @@index([groupId])
}

/// Scoped faculty/group access for STAFF users.
/// A STAFF user with no rows here retains unrestricted access (MVP fallback).
/// ROOT users bypass this table entirely.
model StaffAssignment {
  id        String   @id @default(cuid())
  userId    String
  facultyId String
  groupId   String?
  createdAt DateTime @default(now())
  user      User     @relation("StaffAssignments", fields: [userId], references: [id], onDelete: Cascade)
  faculty   Faculty  @relation("FacultyStaffAssignments", fields: [facultyId], references: [id], onDelete: Cascade)
  group     Group?   @relation("GroupStaffAssignments", fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([userId, facultyId, groupId])
  @@index([userId])
  @@index([facultyId])
}
