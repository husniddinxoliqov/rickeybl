# ─────────────────────────────────────────────────────────────────────────────
# SamDU Mini-App — backend environment template
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=******localhost:5432/rickeybl?schema=public

# JWT secret — must be at least 32 characters and random in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_in_production

# JWT expiry for students (default 7d); staff/root tokens expire in 1d regardless
JWT_EXPIRES_IN=7d

# Telegram Bot Token from @BotFather (required for Telegram auth)
BOT_TOKEN=your_telegram_bot_token

# Root admin credentials — change before first deployment
ROOT_USERNAME=admin
ROOT_EMAIL=admin@example.local
ROOT_PASSWORD=your_root_password_here

# Server port (default 3000)
PORT=3000

# Allowed frontend origins for browser requests. Use comma-separated values in production.
# Example: CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:8080

# Set to "true" while in pilot/test mode — shows TEST MODE banner in the UI
TEST_MODE=true

# Set to "production" to enforce strict config checks at startup
# NODE_ENV=production

# Set to "true" alongside SEED_RESET=true ONLY when you intentionally want to
# wipe production data.  Ignored outside production (NODE_ENV != production).
# ALLOW_PROD_RESET=true
